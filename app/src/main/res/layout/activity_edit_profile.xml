<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/light_gray">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/baseline_arrow_back_24"
            app:title="Edytuj profil"
            app:titleTextColor="@color/black"
            android:background="@color/light_gray"/>
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Imię -->
            <EditText
                android:id="@+id/name_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_medium"
                android:autofillHints="password"
                android:drawableStart="@drawable/baseline_person_24"
                android:drawablePadding="@dimen/margin_medium"
                android:hint="Imię"
                android:inputType="text"
                android:minHeight="@dimen/input_min_height"
                android:textSize="@dimen/text_medium" />

            <!-- Nazwisko -->
            <EditText
                android:id="@+id/surname_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_medium"
                android:autofillHints="password"
                android:drawableStart="@drawable/baseline_person_24"
                android:drawablePadding="@dimen/margin_medium"
                android:hint="Nazwisko"
                android:inputType="text"
                android:minHeight="@dimen/input_min_height"
                android:textSize="@dimen/text_medium" />

            <!-- Email -->
            <EditText
                android:id="@+id/email_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_medium"
                android:autofillHints="password"
                android:drawableStart="@drawable/baseline_email_24"
                android:drawablePadding="@dimen/margin_medium"
                android:hint="Email"
                android:inputType="text"
                android:minHeight="@dimen/input_min_height"
                android:textSize="@dimen/text_medium" />

            <!-- Sekcja zmiany hasła -->
            <TextView
                android:id="@+id/change_password_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Zmień hasło"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="24dp" />

            <!-- Aktualne hasło -->
            <EditText
                android:id="@+id/current_password_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_medium"
                android:autofillHints="password"
                android:drawableStart="@drawable/baseline_lock_24"
                android:drawablePadding="@dimen/margin_medium"
                android:hint="Aktualne hasło"
                android:inputType="textPassword"
                android:minHeight="@dimen/input_min_height"
                android:textSize="@dimen/text_medium" />

            <!-- Nowe hasło -->
            <EditText
                android:id="@+id/new_password_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_medium"
                android:autofillHints="password"
                android:drawableStart="@drawable/baseline_lock_24"
                android:drawablePadding="@dimen/margin_medium"
                android:hint="Nowe hasło"
                android:inputType="textPassword"
                android:minHeight="@dimen/input_min_height"
                android:textSize="@dimen/text_medium" />

            <!-- Potwierdź nowe hasło -->
            <EditText
                android:id="@+id/confirm_password_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_medium"
                android:autofillHints="password"
                android:drawableStart="@drawable/baseline_lock_24"
                android:drawablePadding="@dimen/margin_medium"
                android:hint="Powtórz hasło"
                android:inputType="textPassword"
                android:minHeight="@dimen/input_min_height"
                android:textSize="@dimen/text_medium" />

            <!-- Przycisk zapisz zmiany -->

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/save_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_large"
                android:background="@drawable/login_btn"
                android:backgroundTint="@color/gray"
                android:minWidth="@dimen/button_min_width"
                android:minHeight="@dimen/button_min_height"
                android:paddingStart="@dimen/margin_medium"
                android:paddingEnd="@dimen/margin_medium"
                android:text="Zapisz zmiany"
                android:textSize="@dimen/text_medium"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/password" />
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
